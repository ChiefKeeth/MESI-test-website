{
  "name": "mesi-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:css": "tailwindcss -i ./input.css -o ./output.css --watch",
    "serve": "node serve.mjs",
    "start": "concurrently -n css,serve -c cyan,green \"npm run dev:css\" \"npm run serve\"",
    "build": "tailwindcss -i ./input.css -o ./output.css --minify"
  },
  "dependencies": {
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "tailwindcss": "^3.4.19"
  }
}
